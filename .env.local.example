# Copy this file to .env.local and fill in your API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Confluence Cloud integration — pulls TServer reference/runbook context into
# the analysis prompt. Optional: analysis still runs without it, just without
# domain-specific grounding (fails open, same as pe-knowledgebot).
# Reuses the same tenant/service-account credentials as pe-knowledgebot — copy
# the values from that app's .env.local rather than issuing a new API token.
CONFLUENCE_BASE_URL=https://motionpoint.atlassian.net
CONFLUENCE_EMAIL=service-account-email@motionpoint.com
CONFLUENCE_API_TOKEN=your_confluence_api_token_here

# Comma-separated numeric page IDs, OR'd together in CQL as the search scope.
# These are the "TServer Release Notes", "Master Properties", and "Site Down"
# folders under Operations > Platform Engineering HQ > KB App Files >
# Reference & Runbooks. Resolved once via a manual CQL lookup — do not resolve
# these at runtime.
CONFLUENCE_ANCESTOR_IDS=1789460493,1789722838,1804075011

# Shared basic auth credentials (same values used in the pe-commandcenter links)
BASIC_AUTH_USER=your_shared_username
BASIC_AUTH_PASSWORD=your_shared_password
